{
    "model": "deepseek/deepseek-v4-pro",
    "autoupdate": true,
    "lsp": true,
    "mcp": {
        "agentmemory": {
            "command": [
                "{{HOME}}/.local/bin/agentmemory-mcp-safe"
            ],
            "enabled": true,
            "type": "local"
        },
        "chrome-devtools": {
            "command": [
                "{{HOME}}/.local/bin/chrome-devtools-mcp-safe"
            ],
            "enabled": true,
            "type": "local"
        },
        "codegraph": {
            "type": "local",
            "command": [
                "codegraph",
                "serve",
                "--mcp"
            ],
            "enabled": true
        },
        "lean-ctx": {
            "command": [
                "{{HOME}}/.local/bin/lean-ctx"
            ],
            "enabled": true,
            "environment": {
                "LEAN_CTX_DATA_DIR": "{{HOME}}/.lean-ctx"
            },
            "type": "local"
        },
        "maru-deep-pro-search": {
            "type": "local",
            "command": [
                "{{HOME}}/.local/bin/maru-deep-pro-search"
            ],
            "enabled": true
        },
        "open-design": {
            "enabled": true,
            "type": "local",
            "command": [
                "{{HOME}}/.local/bin/od",
                "mcp"
            ]
        },
        "playwright": {
            "command": [
                "{{HOME}}/.local/bin/playwright-mcp-safe"
            ],
            "enabled": true,
            "type": "local"
        }
    },
    "permission": {
        "*": "allow",
        "doom_loop": "ask",
        "external_directory": "allow",
        "bash": {
            "shutdown *": "deny",
            "reboot *": "deny",
            "halt *": "deny",
            "poweroff *": "deny",
            "sudo shutdown*": "deny",
            "sudo reboot*": "deny",
            "sudo halt*": "deny",
            "sudo poweroff*": "deny",
            "rm -rf /*": "deny",
            "rm -rf ~": "deny",
            "rm -rf {{HOME}}": "deny",
            "dd if=* of=/dev/*": "deny",
            "diskutil eraseDisk*": "deny",
            "diskutil eraseVolume*": "deny",
            "diskutil partitionDisk*": "deny",
            "mkfs.*": "deny",
            "chmod -R 777 /*": "deny",
            "chmod -R 000 /*": "deny",
            "mv /* /dev/null*": "deny",
            "> /dev/sda*": "deny",
            "> /dev/nvme*": "deny",
            "*": "allow"
        }
    },
    "agent": {
        "plan": {
            "description": "Strategic planning and coordination agent. Use for: analyzing complex requirements, decomposing tasks into parallelizable work units, architectural decisions, code analysis without modification, creating implementation plans, and coordinating multi-step workflows.",
            "mode": "primary",
            "temperature": 0.1,
            "prompt": "{file:./.opencode/prompts/plan.md}",
            "tools": {
                "write": false,
                "edit": false,
                "patch": false,
                "bash": false,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": true,
                "lean-ctx*": true,
                "maru-deep-pro-search*": true,
                "agentmemory*": true
            }
        },
        "build": {
            "description": "Primary implementation agent with full tool access. Use for: writing new code, editing existing files, running build commands, executing tests, installing dependencies, and any task requiring file system modifications or shell access.",
            "mode": "primary",
            "temperature": 0.2,
            "prompt": "{file:./.opencode/prompts/build.md}",
            "tools": {
                "write": true,
                "edit": true,
                "patch": true,
                "bash": true,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": true,
                "lean-ctx*": true,
                "maru-deep-pro-search*": true,
                "agentmemory*": true,
                "chrome-devtools*": true,
                "playwright*": true
            }
        },
        "reviewer": {
            "description": "Code review and quality assessment agent. Use when you need to: review code changes for bugs or issues, assess code quality and maintainability, check for anti-patterns or code smells, evaluate architectural decisions, or provide feedback on pull requests without making changes.",
            "mode": "primary",
            "temperature": 0.1,
            "tools": {
                "write": false,
                "edit": false,
                "patch": false,
                "bash": false,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": false,
                "lean-ctx*": true
            }
        },
        "scout": {
            "description": "Fast codebase exploration agent. Use when you need to: quickly find files by pattern or name, search for specific code patterns or keywords, understand directory structure, locate function or class definitions, or answer questions about what exists in the codebase.",
            "mode": "subagent",
            "temperature": 0.0,
            "tools": {
                "write": false,
                "edit": false,
                "patch": false,
                "bash": false,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": false,
                "lean-ctx*": true
            }
        },
        "research": {
            "description": "Documentation and API research agent. Use when you need to: look up library documentation, find API references, research best practices, understand framework patterns, check package versions or compatibility, or gather information from external sources before implementation.",
            "mode": "subagent",
            "temperature": 0.3,
            "tools": {
                "write": false,
                "edit": false,
                "patch": false,
                "bash": false,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": true,
                "lean-ctx*": true,
                "maru-deep-pro-search*": true,
                "agentmemory*": true,
                "chrome-devtools*": true,
                "playwright*": true
            }
        },
        "debug": {
            "description": "Bug investigation and debugging agent. Use when you need to: investigate runtime errors, trace execution flow, analyze stack traces, examine logs, bisect commits to find regressions, or diagnose performance issues.",
            "mode": "subagent",
            "temperature": 0.2,
            "tools": {
                "write": false,
                "edit": false,
                "patch": false,
                "bash": true,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": false,
                "lean-ctx*": true,
                "agentmemory*": true
            }
        },
        "tester": {
            "description": "Test creation and validation agent. Use when you need to: write unit tests, integration tests, or end-to-end tests, run existing test suites, analyze test coverage, fix failing tests, or validate that code changes don't break existing functionality.",
            "mode": "subagent",
            "temperature": 0.2,
            "tools": {
                "write": true,
                "edit": true,
                "patch": false,
                "bash": true,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": false,
                "lean-ctx*": true
            }
        },
        "refactor": {
            "description": "Code refactoring agent. Use when you need to: improve code structure without changing behavior, extract methods or classes, rename variables for clarity, reduce code duplication, apply design patterns, or modernize legacy code.",
            "mode": "subagent",
            "temperature": 0.2,
            "tools": {
                "write": false,
                "edit": true,
                "patch": false,
                "bash": false,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": false,
                "lean-ctx*": true
            }
        },
        "devops": {
            "description": "Infrastructure and DevOps agent. Use when you need to: write or modify Dockerfiles, create Kubernetes manifests, configure CI/CD pipelines (GitHub Actions, GitLab CI), manage Terraform or infrastructure-as-code, handle cloud provider configurations, set up monitoring or logging, or troubleshoot deployment issues.",
            "mode": "subagent",
            "temperature": 0.1,
            "tools": {
                "write": true,
                "edit": true,
                "patch": true,
                "bash": true,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": true,
                "lean-ctx*": true,
                "maru-deep-pro-search*": true,
                "chrome-devtools*": true,
                "agentmemory*": true,
                "playwright*": true
            }
        },
        "security": {
            "description": "Security auditing agent. Use when you need to: scan for vulnerabilities in dependencies, identify security anti-patterns in code, audit authentication or authorization logic, check for secrets or credentials in code, review input validation, assess API security, or generate security reports.",
            "mode": "subagent",
            "temperature": 0.1,
            "tools": {
                "write": false,
                "edit": false,
                "patch": false,
                "bash": true,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": false,
                "lean-ctx*": true,
                "agentmemory*": true
            }
        },
        "docs": {
            "description": "Documentation agent. Use when you need to: write or update README files, create API documentation, generate code comments or docstrings, write architecture decision records, create user guides, or maintain changelog entries.",
            "mode": "subagent",
            "temperature": 0.3,
            "tools": {
                "write": true,
                "edit": true,
                "patch": false,
                "bash": false,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": false,
                "lean-ctx*": true
            }
        },
        "migrate": {
            "description": "Database and schema migration agent. Use when you need to: create or modify database migrations, update ORM schemas (Prisma, Drizzle, TypeORM), write SQL migration scripts, handle data backfills, manage schema versioning, or coordinate database changes across environments.",
            "mode": "subagent",
            "temperature": 0.1,
            "tools": {
                "write": true,
                "edit": true,
                "patch": false,
                "bash": true,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": false,
                "lean-ctx*": true
            }
        },
        "perf": {
            "description": "Performance profiling and optimization agent. Use when you need to: analyze bundle sizes, run lighthouse audits, profile memory usage, identify performance bottlenecks, optimize database queries, measure load times, or investigate memory leaks.",
            "mode": "subagent",
            "temperature": 0.2,
            "tools": {
                "write": false,
                "edit": false,
                "patch": false,
                "bash": true,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": false,
                "lean-ctx*": true,
                "chrome-devtools*": true,
                "playwright*": true
            }
        },
        "api": {
            "description": "API design and integration agent. Use when you need to: design REST or GraphQL APIs, create OpenAPI/Swagger specifications, generate API clients or SDKs, implement API versioning, write contract tests, or integrate with external APIs.",
            "mode": "subagent",
            "temperature": 0.2,
            "tools": {
                "write": true,
                "edit": true,
                "patch": false,
                "bash": true,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": true,
                "lean-ctx*": true,
                "maru-deep-pro-search*": true,
                "chrome-devtools*": true,
                "agentmemory*": true,
                "playwright*": true
            }
        },
        "data": {
            "description": "Data pipeline and transformation agent. Use when you need to: build ETL pipelines, transform data with pandas/polars, create dbt models, write Spark jobs, design data workflows, or implement data validation and quality checks.",
            "mode": "subagent",
            "temperature": 0.2,
            "tools": {
                "write": true,
                "edit": true,
                "patch": false,
                "bash": true,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "webfetch": false,
                "lean-ctx*": true
            }
        }
    },
    "plugin": [
        "opencode-vibeguard",
        "opencode-notify",
        "opencode-smart-title",
        "opencode-handoff",
        "opencode-synced",
        "opencode-mystatus",
        "@tarquinen/opencode-dcp@latest"
    ]
}
